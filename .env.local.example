# LLMプロバイダーの選択: "anthropic"（デフォルト）または "google"
LLM_PROVIDER=anthropic

# Anthropic を使う場合
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google を使う場合
GOOGLE_API_KEY=your_google_api_key_here
# 使用するGeminiモデル（省略時: gemini-1.5-flash）
# 例: gemini-1.5-flash / gemini-1.5-pro / gemini-2.0-flash
# GOOGLE_MODEL=gemini-1.5-flash
